# QuickLendX Backend Configuration
# Copy this file to .env and fill in your values

# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://localhost:5432/quicklendx_dev
DATABASE_POOL_SIZE=10

# Security (NEVER commit real secrets!)
# Generate with: openssl rand -base64 64
JWT_SECRET=development-jwt-secret-minimum-32-characters-long-for-security-purposes
API_KEY=dev-api-key-minimum-16-chars
ENCRYPTION_KEY=development-encryption-key-minimum-32-characters-required-here

# Stellar Network (Testnet)
STELLAR_NETWORK_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Features
ENABLE_RATE_LIMITING=true
MAX_REQUESTS_PER_MINUTE=100

# Monitoring (optional)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
