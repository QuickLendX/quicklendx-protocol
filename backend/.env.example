# Copy this file to .env and fill in values for local development.
# Never commit .env — it is in .gitignore.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Stellar / Soroban RPC ─────────────────────────────────────────────────────
# Public RPC endpoint — no secret required for read-only access.
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Max requests per IP per minute (default: 100).
RATE_LIMIT_POINTS=100

# ── API keys (staging/prod only) ──────────────────────────────────────────────
# Set via CI secrets or a secrets manager — never hardcode here.
# ADMIN_API_KEY=
# WEBHOOK_SECRET=
