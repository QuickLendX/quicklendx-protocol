{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "types": ["jest", "node"]
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "src/controllers/v1/api-keys.ts",
    "src/routes/v1/monitoring.ts",
    "src/services/mockDataProviders.ts",
    "src/tests/bidsApi.test.ts",
    "src/tests/database.test.ts",
    "src/tests/perf/seed.ts"
  ]
}
